{
  "name": "evoswarm-app",
  "version": "1.0.0",
  "description": "EVOSWARM: Rise of Titans — application mobile (Capacitor wrap iOS/Android).",
  "private": true,
  "scripts": {
    "sync": "cap sync",
    "ios": "cap sync ios && cap open ios",
    "android": "cap sync android && cap open android",
    "add:ios": "cap add ios",
    "add:android": "cap add android",
    "assets": "capacitor-assets generate --iconBackgroundColor '#05060f' --splashBackgroundColor '#05060f'"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/android": "^6.1.0"
  }
}
